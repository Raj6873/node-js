<%- include('Header') %>
<div class="page-wrapper">
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">Admin Details</h4>
                <div class="ml-auto text-right">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/myprofile">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Admin Profile</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title mb-4">Admin Information</h5>
                    <table class="table table-bordered table-striped">
                        <thead class="thead-dark">
                            <tr>
                                <th>Name</th>
                                <th>Image</th>
                                <th>gender</th>
                                <th>City</th>
                                <th>hobby</th>
                                <th>massage</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><%= AdminDataa.name %></td>
                                <td><img src="<%= AdminDataa.image %>" alt="Admin Image" height="50" class="img-thumbnail"></td>
                                <td><%= AdminDataa.gender %></td>
                                <td><%= AdminDataa.city %></td>
                                <td><%= AdminDataa.hobby %></td>
                                <td><%= AdminDataa.massage %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
<%- include('Footer') %>
